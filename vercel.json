{
  "headers": [
    {
      "source": "/logo/site.webmanifest",
      "headers": [
        { "key": "Content-Type", "value": "application/manifest+json; charset=utf-8" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/", "destination": "/frontend/index.html" },
    { "source": "/assets/(.*)", "destination": "/frontend/assets/$1" },
    { "source": "/chat", "destination": "/frontend/chat.html" },
    { "source": "/login", "destination": "/frontend/login.html" },
    { "source": "/journal", "destination": "/frontend/journal.html" },
    { "source": "/planner", "destination": "/frontend/planner.html" },
    { "source": "/chat.html", "destination": "/frontend/chat.html" },
    { "source": "/login.html", "destination": "/frontend/login.html" },
    { "source": "/journal.html", "destination": "/frontend/journal.html" },
    { "source": "/planner.html", "destination": "/frontend/planner.html" },
    { "source": "/app.html", "destination": "/frontend/chat.html" },
    { "source": "/auth.html", "destination": "/frontend/login.html" },
    { "source": "/diary.html", "destination": "/frontend/journal.html" }
  ],
  "trailingSlash": false
}
