{
  "version": 2,
  "name": "brias",
  "buildCommand": null,
  "outputDirectory": "frontend",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://brias-backend.onrender.com/api/:path*"
    },
    {
      "source": "/health",
      "destination": "https://brias-backend.onrender.com/health"
    },
    { "source": "/login", "destination": "/login.html" },
    { "source": "/app",   "destination": "/app.html"   },
    { "source": "/",      "destination": "/index.html"  }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "DENY"    }
      ]
    }
  ]
}
