# BRIAS Configuration
# Copy this to .env and fill in your values

# LLM Settings
LLM_API_URL=http://localhost:8080/v1/chat/completions
LLM_MODEL=mistral

# Server Settings  
HOST=0.0.0.0
PORT=8000

# Security
SECRET_KEY=change-this-to-a-random-secret-key

# BRIAS Core Loop
THOUGHT_INTERVAL_SECONDS=30
DREAM_THRESHOLD_MINUTES=60

# Creator
CREATOR_USERNAME=joey
