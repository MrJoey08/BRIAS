# BRIAS — Omgevingsvariabelen
# Kopieer dit naar .env en vul in

# --- LLM Backend ---
# "llamacpp" voor lokale Mistral, "openai" voor cloud, "anthropic" voor Claude
LLM_BACKEND=llamacpp

# llama.cpp lokaal (OpenAI-compatible endpoint)
LLAMACPP_BASE_URL=http://localhost:8080/v1
LLAMACPP_MODEL=mistral

# OpenAI (als je cloud gebruikt)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# Anthropic (toekomstig)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Logging ---
LOG_LEVEL=INFO
